{
	"schemaVersion": 1,
	"id": "experience-gatling-gun",
	"version": "${version}",
	"name": "Experience Gatling Gun",
	"description": "A simple mod that adds a new weapon to the game: the Experience Gatling Gun.",
	"authors": [
		"VTK"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/experience-gatling-gun/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.egg.ExperienceGatlingGun"
		],
		"client": [
			"com.egg.client.ExperienceGatlingGunClient"
		],
		"fabric-datagen": [
			"com.egg.client.ExperienceGatlingGunDataGenerator"
		]
	},
	"mixins": [
		"experience-gatling-gun.mixins.json",
		{
			"config": "experience-gatling-gun.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
